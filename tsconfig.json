{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": { "@shared/*": ["./src/shared/*"] }
  },
  "include": ["src"],
  "comment_exclude": "platform/electrobun、src/bun、renderer/main.electrobun.tsx 用 bun:sqlite/electrobun 等 Bun 专有模块,由 Bun 自身编译/检查,不纳入 node tsc 与 electron-vite。",
  "exclude": ["src/main/platform/electrobun", "src/bun", "src/renderer/main.electrobun.tsx"]
}
