{
  "name": "cc-move-session",
  "version": "0.1.0",
  "description": "Move Claude Code sessions between projects",
  "author": "cc-move-session",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "test": "node scripts/test-electron.mjs run",
    "test:watch": "node scripts/test-electron.mjs",
    "test:coverage": "node scripts/test-electron.mjs run --coverage",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "e2e": "npm run build && playwright test"
  },
  "build": {
    "appId": "com.local.cc-move-session",
    "productName": "cc-move-session",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "tar": "^7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "~5.1",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
