{
  "name": "cc-session-manager-gui",
  "version": "1.0.0",
  "description": "Manage Claude Code sessions: move, snapshot, archive and restore (desktop GUI)",
  "author": "cc-session-manager-gui",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run bun:dev",
    "dev:electron": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "bun run bun:build",
    "build:electron": "electron-vite build",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "test": "node scripts/test-electron.mjs run",
    "test:watch": "node scripts/test-electron.mjs",
    "test:coverage": "node scripts/test-electron.mjs run --coverage",
    "pack": "npm run build:electron && electron-builder --dir",
    "dist": "npm run build:electron && electron-builder",
    "e2e": "npm run build:electron && playwright test",
    "bun:build:worker": "bun run scripts/build-electrobun-worker.mjs",
    "bun:build": "bun run bun:build:worker && bunx electrobun build",
    "bun:dev": "bun run bun:build:worker && bunx electrobun dev",
    "pack:portable": "bun run scripts/pack-portable.mjs",
    "test:bun": "bun run spike/probe-repository.ts && bun run spike/probe-sqlite.ts && bun run spike/probe-fsmove.ts && bun run spike/probe-paths.ts"
  },
  "build": {
    "appId": "com.local.cc-session-manager-gui",
    "productName": "cc-session-manager-gui",
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/zstd-napi/**"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tar": "^7.5.16",
    "zstd-napi": "^0.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "~5.1",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "electrobun": "^1.18.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
